# Haul.AI Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haulai
REDIS_URL=redis://localhost:6379

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Payments (Stripe)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_FLEET=

# Load Boards
DAT_CLIENT_ID=
DAT_CLIENT_SECRET=
DAT_API_BASE=https://api.dat.com
TRUCKSTOP_API_KEY=
TRUCKSTOP_API_BASE=https://api.truckstop.com

# Email OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/gmail/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Voice (Bland.ai)
BLAND_AI_API_KEY=
BLAND_AI_PHONE_NUMBER=

# File Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=haulai-documents

# Monitoring
SENTRY_DSN=
AXIOM_TOKEN=
POSTHOG_KEY=

# Free APIs
EIA_API_KEY=
OPENROUTESERVICE_API_KEY=
GOOGLE_MAPS_API_KEY=
NOAA_API_BASE=https://api.weather.gov
FMCSA_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
NODE_ENV=development
ENCRYPTION_KEY=
